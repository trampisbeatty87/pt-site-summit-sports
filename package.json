{
  "name": "pt-website-template",
  "version": "1.0.0",
  "description": "Parameterized physical therapy website template. All client content lives in content.json; build.js renders it to static HTML.",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "serve": "node build.js && node -e \"const h=require('http'),f=require('fs'),p=require('path');h.createServer((q,s)=>{let u=q.url==='/'?'/index.html':q.url;let fp=p.join('dist',u.split('?')[0]);f.readFile(fp,(e,d)=>{if(e){s.writeCode=404;s.end('404');return}const t={'.html':'text/html','.css':'text/css','.js':'text/javascript','.jpg':'image/jpeg','.png':'image/png','.svg':'image/svg+xml'}[p.extname(fp)]||'text/plain';s.writeHead(200,{'Content-Type':t});s.end(d)})}).listen(8080,()=>console.log('http://localhost:8080'))\""
  }
}
